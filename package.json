{
  "name": "action-approval-skill",
  "version": "0.1.0",
  "description": "Local dry-run approval packet generator for agent side-effect plans.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "action-approval-skill": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "docs",
    "fixtures",
    "README.md"
  ],
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "smoke": "npm run build && node dist/cli.js plan fixtures/slack-message.json --format markdown",
    "package:smoke": "npm pack --dry-run"
  }
}
